# ConfuseCode — Caddy site block.
#
# IMPORTANT: this VPS already serves basantarana.com. Do NOT replace
# /etc/caddy/Caddyfile — APPEND this block to it, so the existing site keeps
# working. Caddy routes by hostname, so the two coexist happily.
#
#   sudo nano /etc/caddy/Caddyfile     # paste this at the end
#   sudo caddy validate --config /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#
# Caddy obtains and renews HTTPS certificates automatically. Point the
# confusecode.com DNS A record at this server's IP BEFORE reloading, or the
# certificate request will fail (Let's Encrypt has to reach the domain).

confusecode.com, www.confusecode.com {
	encode zstd gzip

	# ---- Security headers ---------------------------------------------------
	# These are the authoritative ones. The dev-time headers in next.config.mjs
	# are a convenience; in production, Caddy is the boundary.
	header {
		# Force HTTPS for a year, including subdomains.
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "no-referrer"
		# Don't advertise what we're running.
		-Server
	}

	# ---- The API --------------------------------------------------------------
	# /api/* goes STRAIGHT to Fastify, not through Next.js. One fewer hop, and it
	# keeps the browser on a single origin — which is what makes the session
	# cookie work at all (a cross-origin API would need CORS + SameSite=None,
	# and SameSite=None is exactly the CSRF exposure we designed out).
	handle /api/* {
		reverse_proxy 127.0.0.1:4000 {
			# Mirrors the backend's own 2 MB bodyLimit. Reject oversized uploads
			# at the edge so they never reach Node.
			request_body {
				max_size 2MB
			}
		}
	}

	# ---- Everything else: the Next.js app ------------------------------------
	# Port 3001, because 3000 belongs to basantarana.com on this host.
	handle {
		reverse_proxy 127.0.0.1:3001
	}

	# Never log request bodies — they contain the user's source code (§7.9).
	# Caddy doesn't log bodies by default; this just keeps the access log lean.
	log {
		output file /var/log/caddy/confusecode.log
		format console
	}
}
