# Backend configuration (all optional in Phases 1–4 — sane defaults in src/config.ts)
PORT=4000
HOST=127.0.0.1
# Origin allowed to call the API. In dev this is the Next.js dev server.
ALLOWED_ORIGIN=http://localhost:3000

# ---- Phase 5 (accounts + database) ----
# Required only once you run Phase 5 features. The stateless core never uses these.
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://confusecode:changeme@localhost:5432/confusecode
# Set to "true" to require TLS to the database (recommended in production).
DATABASE_SSL=false
