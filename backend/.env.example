# Backend configuration.
#
# Phases 1–4 (the stateless analyzer) need NOTHING here — sane defaults live in
# src/config.ts. Everything below the Phase 5 line is opt-in: leave DATABASE_URL
# or COOKIE_SECRET unset and the server boots in stateless mode with no accounts,
# no cookies, and no database connection. That is a supported way to run it.

PORT=4000
HOST=127.0.0.1
# Origin allowed to call the API. In dev this is the Next.js dev server.
ALLOWED_ORIGIN=http://localhost:3000

# =============================================================================
# Phase 5 — accounts + learning history. All of this is OPTIONAL.
# =============================================================================

# The origin the BROWSER sees (not the backend's own port). OAuth redirect URIs
# are built from this, so it must match what you registered with the provider.
# Dev: http://localhost:3000   Prod: https://confusecode.com
PUBLIC_ORIGIN=http://localhost:3000

# ---- Database ---------------------------------------------------------------
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://confusecode:changeme@localhost:5432/confusecode
# Require TLS to the database. Leave false for local dev; set true in production.
DATABASE_SSL=false

# ---- Cookies ----------------------------------------------------------------
# Signs the short-lived OAuth `state` cookie. REQUIRED when accounts are enabled.
# Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=
# Secure cookies (HTTPS only). MUST be true in production.
COOKIE_SECURE=false

# ---- OAuth providers --------------------------------------------------------
# Configure either, both, or neither. A provider with no credentials simply isn't
# offered as a login button — the app doesn't break, the button just isn't there.
#
# GitHub:  https://github.com/settings/developers  → New OAuth App
#          Authorization callback URL: <PUBLIC_ORIGIN>/api/auth/github/callback
#          Scope requested: read:user  (profile only — no repo access, ever)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google:  https://console.cloud.google.com/apis/credentials → OAuth client ID
#          Authorized redirect URI: <PUBLIC_ORIGIN>/api/auth/google/callback
#          Scopes requested: openid email profile
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Retention (§9.5) -------------------------------------------------------
# How long saved learning history is kept before the hourly purge deletes it.
# Set 0 to keep until the user deletes it themselves.
HISTORY_RETENTION_DAYS=365
